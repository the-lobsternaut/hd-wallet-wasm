{
  "name": "hd-wallet-wasm",
  "version": "1.6.0",
  "description": "Comprehensive HD Wallet implementation in WebAssembly - BIP-32/39/44, multi-curve, multi-chain support",
  "type": "module",
  "main": "src/index.mjs",
  "module": "src/index.mjs",
  "types": "src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.mjs"
    },
    "./aligned": {
      "types": "./src/aligned.d.ts",
      "import": "./src/aligned.mjs"
    },
    "./attestation": {
      "import": "./src/epm-attestation.mjs"
    },
    "./wasm": {
      "types": "./dist/index.d.ts",
      "import": "./dist/hd-wallet.js"
    }
  },
  "files": [
    "src/index.mjs",
    "src/index.d.ts",
    "src/epm-attestation.mjs",
    "src/aligned.mjs",
    "src/aligned.d.ts",
    "src/generated/",
    "dist/hd-wallet.js",
    "dist/hd-wallet.wasm",
    "dist/index.d.ts",
    "README.md"
  ],
  "scripts": {
    "generate": "node ../scripts/generate-aligned.mjs",
    "build": "npm run generate && cmake --build ../build-wasm --target hd_wallet_wasm_npm -j",
    "test:artifact": "node test/test_bundle_browser_artifact.mjs",
    "test:all": "node test/test_all.mjs",
    "test": "npm run test:artifact && npm run test:all",
    "test:bip39": "node test/test_bip39.mjs",
    "test:bip32": "node test/test_bip32.mjs",
    "test:vectors": "node test/test_vectors.mjs",
    "test:aligned": "node test/test_aligned.mjs",
    "prepublishOnly": "echo 'Build handled by CI'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DigitalArsenal/hd-wallet-wasm.git"
  },
  "keywords": [
    "hd-wallet",
    "bip32",
    "bip39",
    "bip44",
    "cryptocurrency",
    "bitcoin",
    "ethereum",
    "solana",
    "cosmos",
    "polkadot",
    "wasm",
    "webassembly",
    "secp256k1",
    "ed25519",
    "p256",
    "p384",
    "hardware-wallet",
    "trezor",
    "ledger",
    "keepkey"
  ],
  "author": "DigitalArsenal",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/DigitalArsenal/hd-wallet-wasm/issues"
  },
  "homepage": "https://digitalarsenal.github.io/hd-wallet-wasm/",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}
